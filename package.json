{
  "name": "ccpocket",
  "description": "Mobile client for Claude Code and Codex with WebSocket bridge server",
  "private": true,
  "license": "FSL-1.1-MIT",
  "author": "K9i",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/K9i-0/ccpocket.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "node scripts/setup-hooks.cjs",
    "bridge": "npm run dev --workspace=packages/bridge",
    "bridge:build": "npm run build --workspace=packages/bridge",
    "dev": "node scripts/dev-restart.cjs",
    "setup": "node scripts/setup-launchd.cjs || echo 'Setup skipped on non-macOS platforms'",
    "bridge:doctor": "npm run doctor --workspace=packages/bridge",
    "test:bridge": "npm run test --workspace=packages/bridge",
    "test:bridge:coverage": "npm run test:coverage --workspace=packages/bridge",
    "functions:typecheck": "npm --prefix functions run typecheck",
    "functions:build": "npm --prefix functions run build",
    "functions:deploy": "npm --prefix functions run deploy",
    "shorebird:patch:android": "node .claude/skills/shorebird-patch/patch.cjs android",
    "shorebird:patch:ios": "node .claude/skills/shorebird-patch/patch.cjs ios",
    "shorebird:promote": "node .claude/skills/shorebird-patch/promote.cjs",
    "build:android": "node scripts/build-android.cjs",
    "build:android:release": "node scripts/build-android.cjs --release",
    "build:android:bundle": "node scripts/build-android.cjs --bundle",
    "build:android:clean": "node scripts/build-android.cjs --clean"
  }
}
